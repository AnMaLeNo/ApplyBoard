{
  "manifest_version": 3,
  "name": "Offer Ingestion Tool",
  "version": "1.2.0",
  "description": "Extension sécurisée interagissant avec l'API Fastify via JWT.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Connexion"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://companies.intra.42.fr/en/offers/*"],
      "js": ["content.js"]
    }
  ],
  "permissions": [
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "http://100.84.166.112:8042/*"  
  ]
}